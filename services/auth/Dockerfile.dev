# =============================================================================
# Dockerfile.dev — Auth Service (Development)
# =============================================================================
# Goals:
#   - Fast container start (deps cached in image layer, NOT a volume)
#   - Hot reload via Django runserver
#   - Source code mounted as volume (edit on host → reflected instantly)
#   - venv lives INSIDE the image — never mounted, never deleted on restart
#
# The venv-deletion problem explained and fixed:
#   BAD:  volumes: ["./services/auth:/app"]          ← wipes /app/.venv on mount
#   FIX:  venv goes to /opt/venv (outside /app)      ← volume mount can't touch it
# =============================================================================

FROM python:3.11-slim

WORKDIR /app

# System deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    libpq-dev \
    postgresql-client \
    curl \
    # git needed for any VCS dependencies in pyproject.toml
    git \
    && rm -rf /var/lib/apt/lists/*

# Install uv (pinned — same version as prod for parity)
COPY --from=ghcr.io/astral-sh/uv:0.4.30 /uv /usr/local/bin/uv

# ── Key fix: venv goes to /opt/venv, NOT /app/.venv ──────────────────────────
# When docker-compose mounts ./services/auth → /app, it overlays /app entirely.
# Anything built into /app during the image build (like .venv) gets hidden.
# Putting the venv at /opt/venv means the volume mount never touches it.
ENV UV_LINK_MODE=copy \
    UV_PROJECT_ENVIRONMENT=/opt/venv \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app \
    PATH="/opt/venv/bin:$PATH"

# Copy dependency manifest — cached layer
# Only re-runs uv sync when pyproject.toml or uv.lock changes
COPY pyproject.toml uv.lock /app/

# Install ALL deps (including dev: pytest, ruff, etc.)
RUN uv sync --frozen

# Copy source — this layer is overridden by the volume mount in dev,
# but it means the image works standalone too (e.g. for CI)
COPY . /app/

EXPOSE 8001

# Healthcheck so docker-compose can report ready state
HEALTHCHECK --interval=10s --timeout=5s --start-period=30s --retries=3 \
    CMD curl -f http://localhost:8001/api/health/ || exit 1

# entrypoint.dev.sh handles: wait for DB, run migrations, start server
# Falls back to runserver directly if script not present
CMD ["sh", "-c", \
     "if [ -f /app/entrypoint.dev.sh ]; then \
        chmod +x /app/entrypoint.dev.sh && /app/entrypoint.dev.sh; \
      else \
        python manage.py migrate --noinput && \
        python manage.py runserver 0.0.0.0:8001; \
      fi"]