# Application
APP_NAME=Kraivor
APP_ENV=development
DEBUG=True
SECRET_KEY=your-secret-key-here

# Database (PostgreSQL)
DATABASE_URL=postgresql://kraivor:your-password@localhost:5432/kraivor
POSTGRES_USER=kraivor
POSTGRES_PASSWORD=your-password
POSTGRES_DB=kraivor
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# AWS
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=kraivor-reports

# OpenRouter (LLM API)
OPENROUTER_API_KEY=your-openrouter-api-key

# Pinecone (Vector Database)
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=your-pinecone-env
PINECONE_INDEX_NAME=kraivor-codebase

# OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Email (AWS SES)
AWS_SES_FROM_EMAIL=noreply@kraivor.com

# Firebase (Push Notifications)
FIREBASE_SERVER_KEY=your-firebase-server-key
FIREBASE_SENDER_ID=your-firebase-sender-id

# Slack
SLACK_WEBHOOK_URL=your-slack-webhook-url