						"exec": [
							"pm.test('Status code is 429 when rate limited', function() {",
							"    if (pm.response.code === 429) {",
							"        return true;",
							"    }",
							"    pm.expect(pm.response.code).to.be.oneOf([200, 429]);",
							"});",
							"",
							"pm.test('Rate limited response has retry_after', function() {",
							"    if (pm.response.code === 429) {",
							"        const jsonData = pm.response.json();",
							"        pm.expect(jsonData).to.have.property('code', 'rate_limit_exceeded');",
							"        pm.expect(jsonData).to.have.property('retry_after');",
