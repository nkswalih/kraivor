# =============================================================================
# KRAIVOR ENVIRONMENT CONFIGURATION
# =============================================================================
# This file contains ALL configuration options for the Kraivor project.
# Copy this file to .env and fill in your values.
#
# Environment Variable Priority (12-Factor App):
#   1. System Environment Variables (highest)
#   2. .env file in project root
#   3. Default values in code (lowest)
#
# For local development, just copy to .env and adjust values.
# For production, use your cloud provider's secret management.
# =============================================================================

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Application name
APP_NAME=Kraivor

# Environment: development, staging, production
APP_ENV=development

# Debug mode - MUST be False in production!
# True shows detailed error pages (security risk)
# False shows generic error pages (secure)
DEBUG=True

# Django Secret Key - REQUIRED in production
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
# NEVER share or commit this key!
SECRET_KEY=your-super-secret-key-here-change-in-production

# Allowed hosts - comma-separated list of valid domains
# Django validates Host header to prevent attacks
# Examples:
#   Development: localhost,127.0.0.1,127.0.0.1:3000,localhost:3000
#   Production: yourdomain.com,api.yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1,127.0.0.1:3000,localhost:3000

# =============================================================================
# DATABASE - PostgreSQL
# =============================================================================
# Format: postgresql://USER:PASSWORD@HOST:PORT/NAME
# Examples:
#   Local: postgresql://kraivor:password@localhost:5433/kraivor
#   Docker: postgresql://kraivor:password@postgres:5432/kraivor
#   Production: postgresql://user:password@prod-db.example.com:5432/kraivor

# Database URL (single string with all connection info)
DATABASE_URL=postgresql://kraivor:${DB_PASSWORD}@localhost:5433/kraivor

# Individual database settings (optional, used for Docker)
DB_PASSWORD=your-database-password
POSTGRES_USER=kraivor
POSTGRES_DB=kraivor
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# =============================================================================
# REDIS - Cache & Celery Broker
# =============================================================================
# Format: redis://HOST:PORT/DB_NUMBER
# DB 0: Cache, DB 1: Celery broker, DB 2: Sessions
# Examples:
#   Local: redis://localhost:6379/0
#   Docker: redis://redis:6379/0
#   Production: redis://prod-redis.example.com:6379/0

REDIS_URL=redis://localhost:6379/0

# =============================================================================
# KAFKA - Message Queue
# =============================================================================
# Format: HOST:PORT
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# =============================================================================
# EMAIL - SMTP Configuration
# =============================================================================
# Transactional emails: password reset, verification, notifications
# Examples:
#   Development: localhost:1025 (Mailhog)
#   AWS SES: email-smtp.us-east-1.amazonaws.com:587
#   SendGrid: smtp.sendgrid.net:587
#   Mailgun: smtp.mailgun.org:587

# Email host and port
EMAIL_HOST=localhost
EMAIL_PORT=1025

# SMTP credentials
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Email security
# TLS (Port 587): Use for STARTTLS
# SSL (Port 465): Use for implicit TLS
EMAIL_USE_TLS=false
EMAIL_USE_SSL=false

# Email timeouts (seconds)
EMAIL_TIMEOUT=30

# From address
EMAIL_FROM=noreply@kraivor.com

# Frontend URL for email links
FRONTEND_URL=http://localhost:3000

# =============================================================================
# JWT - JSON Web Token Configuration
# =============================================================================
# RS256 asymmetric keys for JWT signing
# Keys should be in services/auth/.keys/ for local auth service development
# or mounted as absolute paths in staging/production (NOT in git!)
# Generate keys with:
#   openssl genrsa -out .keys/jwt-private.pem 2048
#   openssl rsa -in .keys/jwt-private.pem -pubout -out .keys/jwt-public.pem

# Path to private key (for signing). Relative paths are resolved from services/auth/.
JWT_PRIVATE_KEY_PATH=.keys/jwt-private.pem

# Path to public key (for verification by other services). Relative paths are resolved from services/auth/.
JWT_PUBLIC_KEY_PATH=.keys/jwt-public.pem

# JWT algorithm (RS256 recommended for asymmetric)
JWT_ALGORITHM=RS256

# Token expiration times
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# =============================================================================
# COOKIE CONFIGURATION
# =============================================================================
# Session and refresh token cookie settings

# Cookie security (HTTPS only in production)
COOKIE_SECURE=false

# SameSite policy (Lax for development, Strict for production)
# Lax: Allows cookies on same-site navigation, blocks on cross-site
# Strict: Blocks all cross-site cookies (more secure)
COOKIE_SAMESITE=Lax

# Cookie path
COOKIE_PATH=/auth/

# HTTPOnly (prevent JavaScript access - prevents XSS cookie theft)
COOKIE_HTTPONLY=true

# Cookie domain (empty for current domain, e.g., '.example.com' for all subdomains)
COOKIE_DOMAIN=

# =============================================================================
# CORS - Cross-Origin Resource Sharing
# =============================================================================
# Control which domains can access your API

# Allow all origins (Development only!)
# Production: Set to false and use CORS_ALLOWED_ORIGINS
CORS_ALLOW_ALL_ORIGINS=true
CORS_ALLOW_CREDENTIALS=true

# Specific allowed origins (Production)
# CORS_ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# =============================================================================
# SECURITY HEADERS - PRODUCTION
# =============================================================================
# HTTP security headers (enabled in production)

# Redirect HTTP to HTTPS
SECURE_SSL_REDIRECT=true

# HSTS - Strict-Transport-Security (seconds)
# Recommended: 31536000 (1 year) for production
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=true
SECURE_HSTS_PRELOAD=true

# X-XSS-Protection
SECURE_BROWSER_XSS_FILTER=true

# Prevent MIME type sniffing
SECURE_CONTENT_TYPE_NOSNIFF=true

# X-Frame-Options (DENY or SAMEORIGIN)
X_FRAME_OPTIONS=DENY

# Referrer policy
SECURE_REFERRER_POLICY=strict-origin-when-cross-origin

# Proxy trust (enable when behind load balancer/CDN)
# Format: HTTP_HEADER,expected_value
# Example: HTTP_X_FORWARDED_PROTO,https
SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https

# =============================================================================
# LOGGING
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
DJANGO_LOG_LEVEL=INFO

# =============================================================================
# LOGIN SECURITY
# =============================================================================

# Login failure tracking
LOGIN_MAX_FAILURES=5
LOGIN_LOCKOUT_MINUTES=15

# =============================================================================
# CLOUD SERVICES (Optional)
# =============================================================================

# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=kraivor-reports
AWS_SES_FROM_EMAIL=noreply@kraivor.com

# OpenRouter (LLM API)
OPENROUTER_API_KEY=

# Pinecone (Vector Database)
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=kraivor-codebase

# OAuth Providers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Firebase (Push Notifications)
FIREBASE_SERVER_KEY=
FIREBASE_SENDER_ID=

# Slack (Webhooks)
SLACK_WEBHOOK_URL=

# =============================================================================
# CELERY - Async Tasks
# =============================================================================

# Celery broker URL (usually same Redis, different DB)
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# =============================================================================
# MICROSERVICES - Internal Communication
# =============================================================================

# Internal request header for service-to-service communication
# Other services send this header with a shared token
INTERNAL_REQUEST_HEADER=X-Internal-Request
INTERNAL_REQUEST_TOKEN=

# =============================================================================
# SENTRY - Error Tracking (Optional)
# =============================================================================
# Sign up at sentry.io and create a project
# SENTRY_DSN=https://example@sentry.io/1234567
